# =============================================================================
# YUGI-AI Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development WITHOUT Docker.
# When using Docker Compose, variables are set via docker-compose.dev.yml.
#
# Variables prefixed with NEXT_PUBLIC_ are available in the browser.
# Variables WITHOUT the prefix are server-side only (API routes, SSR).
# =============================================================================

# -----------------------------------------------------------------------------
# Public — Available in the browser (embedded at build time)
# IMPORTANT: These are baked into the JavaScript bundle during `next build`.
# Changing them requires a rebuild.
# -----------------------------------------------------------------------------

# API endpoint — where the frontend sends REST requests
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# WebSocket endpoint — where Socket.IO connects for real-time events
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Application metadata
NEXT_PUBLIC_APP_NAME=YUGI-AI
NEXT_PUBLIC_APP_VERSION=0.1.0-dev

# -----------------------------------------------------------------------------
# Server-Side Only — NOT exposed to the browser
# Used in Next.js API routes and server components.
# -----------------------------------------------------------------------------

# Internal backend URL (for server-side rendering)
# When running in Docker, services communicate via container names.
# When running locally, use localhost.
INTERNAL_API_URL=http://localhost:8000

# Node environment
NODE_ENV=development
