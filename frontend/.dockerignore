# =============================================================================
# YUGI-AI Frontend — Docker Build Ignore
# =============================================================================
# Excludes files from the Docker build context to:
#   - Speed up builds (node_modules is ~500MB+)
#   - Prevent cache invalidation from irrelevant changes
#   - Keep the image clean
# =============================================================================

# Dependencies — installed inside the container
node_modules/
.pnp/
.pnp.js

# Build output — regenerated during docker build
.next/
out/
build/
dist/

# Version control
.git
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment files (secrets from env vars, not files)
.env
.env.local
.env.*.local

# Testing
coverage/
*.lcov

# Documentation
*.md
!README.md

# Docker files (prevent recursive context)
Dockerfile
.dockerignore
docker-compose*.yml

# Storybook
storybook-static/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Turbo
.turbo/

# Vercel
.vercel/
