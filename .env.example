# =============================================================================
# YUGI-AI — Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
#
# Generation commands for secrets:
#   SECRET_KEY:     openssl rand -hex 64
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# -----------------------------------------------------------------------------
# Project
# -----------------------------------------------------------------------------
PROJECT_NAME=yugi-ai
COMPOSE_PROJECT_NAME=yugi-ai
ENVIRONMENT=development
# Options: development | staging | production

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by: docker-compose, backend
# -----------------------------------------------------------------------------
POSTGRES_USER=yugi
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=yugi_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# Used by: docker-compose, backend
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Leave empty for development. Set a strong password in production.

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_WORKERS=1
# Production: set to (2 * CPU_CORES) + 1

# JWT Configuration
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# BYOK Encryption
# Used to encrypt user API keys at rest in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_FERNET_KEY

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:80
# Comma-separated list of allowed origins

# Logging
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# These variables are prefixed with NEXT_PUBLIC_ to be available in the browser.
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
NEXT_PUBLIC_APP_NAME=YUGI-AI
NEXT_PUBLIC_APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# NGINX
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
