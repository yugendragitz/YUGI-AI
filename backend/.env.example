# =============================================================================
# YUGI-AI Backend — Environment Variables
# =============================================================================
# Copy this file to .env for local development WITHOUT Docker.
# When using Docker Compose, variables are set in the root .env file instead.
#
# These values are development defaults — NEVER use in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
# Options: development | staging | production | testing

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# Connection string assembled as:
#   postgresql+asyncpg://{USER}:{PASSWORD}@{HOST}:{PORT}/{DB}
# -----------------------------------------------------------------------------
POSTGRES_USER=yugi
POSTGRES_PASSWORD=yugi_dev_password
POSTGRES_DB=yugi_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection pool settings
# min_size: minimum number of connections kept alive
# max_size: maximum connections (should not exceed PostgreSQL max_connections)
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# -----------------------------------------------------------------------------
# Cache — Redis
# Connection string assembled as:
#   redis://{PASSWORD}@{HOST}:{PORT}/{DB}
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Authentication — JWT
# SECRET_KEY: Used to sign JWT tokens. Generate with: openssl rand -hex 64
# Minimum 64 characters in production.
# -----------------------------------------------------------------------------
SECRET_KEY=dev-secret-key-do-not-use-in-production-please-change-me-now
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT Algorithm
JWT_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Encryption — BYOK API Key Storage
# ENCRYPTION_KEY: Fernet key for encrypting user API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=dev-encryption-key-not-for-production-use-generate-real-one

# -----------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# Comma-separated list of allowed origins.
# In production, this should be your domain only.
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:80

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_WORKERS=1
# Production formula: (2 * CPU_CORES) + 1

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG in development, INFO in production.

# Log format: json (production) | console (development)
LOG_FORMAT=console
